{
	"$schema": "./node_modules/@angular/cli/lib/config/schema.json",
	"version": 1,
	"newProjectRoot": "projects",
	"projects": {
		"mfe5": {
			"projectType": "application",
			"schematics": {
				"@schematics/angular:component": {
					"style": "scss"
				}
			},
			"root": "projects/mfe5",
			"sourceRoot": "projects/mfe5/src",
			"prefix": "app",
			"architect": {
				"build": {
					"builder": "@angular-architects/native-federation-v4:build",
					"options": {
                       	"cacheExternalArtifacts": true
					},
					"configurations": {
						"production": {
							"tsConfig": "projects/mfe5/tsconfig.app.json",
							"target": "mfe5:esbuild:production"
						},
						"development": {
							"target": "mfe5:esbuild:development",
							"dev": true
						}
					},
					"defaultConfiguration": "production"
				},
				"serve": {
					"builder": "@angular-architects/native-federation-v4:build",
					"options": {
						"target": "mfe5:serve-original:development",
						"tsConfig": "projects/mfe5/tsconfig.app.json",
						"cacheExternalArtifacts": true,
						"rebuildDelay": 500,
						"dev": true,
						"port": 0
					}
				},
				"extract-i18n": {
					"builder": "@angular/build:extract-i18n"
				},
				"test": {
					"builder": "@angular/build:karma",
					"options": {
						"polyfills": [],
						"tsConfig": "projects/mfe5/tsconfig.spec.json",
						"inlineStyleLanguage": "scss",
						"assets": [
							{
								"glob": "**/*",
								"input": "projects/mfe5/public"
							}
						],
						"styles": [
							"projects/mfe5/src/styles.scss"
						],
						"scripts": []
					}
				},
				"esbuild": {
					"builder": "@angular/build:application",
					"options": {
						"outputPath": "dist/mfe5",
						"index": "projects/mfe5/src/index.html",
						"browser": "projects/mfe5/src/main.ts",
						"polyfills": [
							"zone.js",
							"es-module-shims"
						],
						"tsConfig": "projects/mfe5/tsconfig.app.json",
						"inlineStyleLanguage": "scss",
						"assets": [
							{
								"glob": "**/*",
								"input": "projects/mfe5/public"
							}
						],
						"styles": [
							"projects/mfe5/src/styles.scss"
						],
						"scripts": []
					},
					"configurations": {
						"production": {
							"budgets": [
								{
									"type": "initial",
									"maximumWarning": "500kB",
									"maximumError": "1MB"
								},
								{
									"type": "anyComponentStyle",
									"maximumWarning": "4kB",
									"maximumError": "8kB"
								}
							],
							"outputHashing": "all"
						},
						"development": {
							"optimization": false,
							"extractLicenses": false,
							"sourceMap": true
						}
					},
					"defaultConfiguration": "production"
				},
				"serve-original": {
					"builder": "@angular/build:dev-server",
					"configurations": {
						"production": {
							"buildTarget": "mfe5:esbuild:production"
						},
						"development": {
							"buildTarget": "mfe5:esbuild:development"
						}
					},
					"defaultConfiguration": "development",
					"options": {
						"port": 4205
					}
				}
			}
		}
		
	},
	"schematics": {

	}
}